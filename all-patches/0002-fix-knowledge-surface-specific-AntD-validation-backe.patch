From 737d45b410ced8216a45fbf0218f7ee9c300e7bc Mon Sep 17 00:00:00 2001
From: Devin AI <158243242+devin-ai-integration[bot]@users.noreply.github.com>
Date: Thu, 23 Apr 2026 21:30:05 +0000
Subject: [PATCH 2/8] fix(knowledge): surface specific AntD validation /
 backend error when creating a question
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Previously the catch around form.validateFields() was swallowing the real
error under a generic 'Не удалось создать вопрос' toast. Split validation
and submission: show the first failing field rule from AntD, or the DRF
error detail when the backend rejects, so the user sees why creation
failed.

Co-Authored-By: Егор Брайт (Светлый) <brait.2005@gmail.com>
---
 .../components/CreateQuestionModal.tsx        | 27 +++++++++++++++----
 1 file changed, 22 insertions(+), 5 deletions(-)

diff --git a/frontend-react/src/features/knowledge/components/CreateQuestionModal.tsx b/frontend-react/src/features/knowledge/components/CreateQuestionModal.tsx
index bd1d208..38915e4 100644
--- a/frontend-react/src/features/knowledge/components/CreateQuestionModal.tsx
+++ b/frontend-react/src/features/knowledge/components/CreateQuestionModal.tsx
@@ -145,25 +145,42 @@ export const CreateQuestionModal: React.FC<CreateQuestionModalProps> = ({
   };
 
   const handleSubmit = async () => {
+    let values;
+    try {
+      values = await form.validateFields();
+    } catch (validationError: any) {
+      const firstError = validationError?.errorFields?.[0]?.errors?.[0];
+      if (firstError) {
+        message.error(firstError);
+      } else {
+        message.error('Заполните обязательные поля');
+      }
+      return;
+    }
+
     try {
-      const values = await form.validateFields();
       setLoading(true);
 
-      // Создаем новый вопрос через API
       const newQuestion = await knowledgeApi.createQuestion({
         title: values.title,
         description: values.description,
         category: values.category,
         tags: tags
       });
-      
+
       message.success('Вопрос успешно создан!');
       form.resetFields();
       setTags([]);
       onSuccess(newQuestion);
-    } catch (error) {
+    } catch (error: any) {
       console.error('Failed to create question:', error);
-      message.error('Не удалось создать вопрос');
+      const backendError =
+        error?.response?.data?.detail ||
+        (typeof error?.response?.data === 'string' ? error.response.data : undefined) ||
+        (error?.response?.data && typeof error.response.data === 'object'
+          ? Object.values(error.response.data).flat().join(', ')
+          : undefined);
+      message.error(backendError || 'Не удалось создать вопрос');
     } finally {
       setLoading(false);
     }
-- 
