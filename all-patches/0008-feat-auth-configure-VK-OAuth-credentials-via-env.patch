From d2db448e98578de334ee22d5675060d848f1bd4d Mon Sep 17 00:00:00 2001
From: "devin-ai-integration[bot]"
 <devin-ai-integration[bot]@users.noreply.github.com>
Date: Fri, 24 Apr 2026 06:58:05 +0000
Subject: [PATCH 8/8] feat(auth): configure VK OAuth credentials via env
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- settings.py: populate SOCIALACCOUNT_PROVIDERS['vk']['APP'] from
  VK_CLIENT_ID / VK_CLIENT_SECRET / VK_SERVICE_KEY env vars (same
  pattern as google)
- .env.example: document VK_SERVICE_KEY and explain what each key is

VK login button уже был на фронте (SocialLoginButtons.tsx),
backend vk_callback тоже существовал — теперь у allauth появились
реальные ключи и /accounts/vk/login/ отдаёт 302 на oauth.vk.com.
---
 .env.example       | 10 +++++++---
 config/settings.py |  8 ++++++++
 2 files changed, 15 insertions(+), 3 deletions(-)

diff --git a/.env.example b/.env.example
index d3463a2..d69c94e 100644
--- a/.env.example
+++ b/.env.example
@@ -35,9 +35,13 @@ FRONTEND_URL=https://okoznaniy.ru
 GOOGLE_CLIENT_ID=your-google-client-id
 GOOGLE_CLIENT_SECRET=your-google-client-secret
 
-# VK OAuth settings
-VK_CLIENT_ID=your-vk-client-id
-VK_CLIENT_SECRET=your-vk-client-secret
+# VK OAuth settings (VK ID / vk.com app)
+# VK_CLIENT_ID — ID приложения (числовой)
+# VK_CLIENT_SECRET — Защищённый ключ (client_secret)
+# VK_SERVICE_KEY — Сервисный ключ доступа (для server-side API вызовов)
+VK_CLIENT_ID=your-vk-app-id
+VK_CLIENT_SECRET=your-vk-secure-key
+VK_SERVICE_KEY=your-vk-service-key
 
 # Support chat settings
 SUPPORT_USER_ID=
diff --git a/config/settings.py b/config/settings.py
index 4ca6f15..18fd8d6 100644
--- a/config/settings.py
+++ b/config/settings.py
@@ -144,6 +144,14 @@ SOCIALACCOUNT_PROVIDERS = {
         'SCOPE': [
             'email',
         ],
+        'AUTH_PARAMS': {
+            'display': 'popup',
+        },
+        'APP': {
+            'client_id': os.getenv('VK_CLIENT_ID', ''),
+            'secret': os.getenv('VK_CLIENT_SECRET', ''),
+            'key': os.getenv('VK_SERVICE_KEY', ''),
+        },
         'LOGIN_REDIRECT_URL': '/api/users/vk/callback/',
     }
 }
-- 
