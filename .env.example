# Django settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
DJANGO_ENV=production

# Database settings
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql://postgres:your-postgres-password@postgres:5432/oko_db

# Redis settings
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://:your-redis-password@redis:6379/0

# Payment encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
PAYMENT_ENCRYPTION_KEY=your-fernet-key-here

# Bot settings
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Security settings
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx,okoznaniy.ru,www.okoznaniy.ru

# Email settings (Yandex)
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@yandex.ru
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=your-email@yandex.ru

# Frontend URL
FRONTEND_URL=https://okoznaniy.ru

# Google OAuth settings
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# VK OAuth settings
VK_CLIENT_ID=your-vk-client-id
VK_CLIENT_SECRET=your-vk-client-secret

# Support chat settings
SUPPORT_USER_ID=
